[submodule "libs/juce"]
	path = libs/juce
	url = https://github.com/juce-framework/JUCE.git
[submodule "libs/assimp"]
	path = libs/assimp
	url = https://github.com/assimp/assimp.git
[submodule "libs/visage"]
	path = libs/visage
	url = https://github.com/VitalAudio/visage.git
[submodule "libs/imgui"]
	path = libs/imgui
	url = https://github.com/ocornut/imgui.git
	branch = docking
[submodule "libs/imgui_juce"]
	path = libs/imgui_juce
	url = https://github.com/Krasjet/imgui_juce.git
