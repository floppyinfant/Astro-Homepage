// ~/.continue/config.json

// # Download des schnellen Modells für die Tab-Vervollständigung
// ollama run qwen3-coder:7b
// # (Optional) Download des großen Modells, falls du den Chat komplett offline nutzen willst
// ollama run qwen3-coder:32b

// openRouter.ai API-Key erforderlich

{
  "models": [
    {
      "title": "DeepSeek V4 Pro (OpenRouter)",
      "provider": "openrouter",
      "model": "deepseek/deepseek-v4-pro",
      "apiKey": "DEIN_OPENROUTER_API_KEY_HIER"
    },
    {
      "title": "GLM-5.2 (OpenRouter)",
      "provider": "openrouter",
      "model": "zhipu/glm-5.2",
      "apiKey": "DEIN_OPENROUTER_API_KEY_HIER"
    },
    {
      "title": "Qwen3 Coder 32B (Lokal)",
      "provider": "ollama",
      "model": "qwen3-coder:32b"
    }
  ],
  "tabAutocompleteModel": {
    "title": "Qwen3 Coder 7B (Lokal Auto-Tab)",
    "provider": "ollama",
    "model": "qwen3-coder:7b"
  },
  "tabAutocompleteOptions": {
    "useCopyBuffer": true,
    "maxPromptTokens": 1024
  },
  "contextProviders": [
    {
      "name": "code",
      "options": {}
    },
    {
      "name": "docs",
      "options": {}
    },
    {
      "name": "terminal",
      "options": {}
    }
  ],
  "slashCommands": [
    {
      "name": "edit",
      "description": "Code direkt im Editor bearbeiten"
    },
    {
      "name": "comment",
      "description": "Kommentare und Docstrings für den Code schreiben"
    },
    {
      "name": "fix",
      "description": "Fehler im ausgewählten Code finden und beheben"
    }
  ]
}
